########################################################################
# HELPER FUNCTIONS
# cheat.sh
function cheat() {
  curl "https://cheat.sh/$1"
}

# use Yazi and exit on cd
function yazy_cd() {
  local tmp=$(mktemp -t "yazi-cwd.XXXXXX") cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(<$tmp)" && [[ -n $cwd ]] && [[ $cwd != $PWD ]]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# deduplicate zsh history file
function history_deduplicate() {
  local before=$(wc -l <~/.zsh_history)
  tail -r ~/.zsh_history | awk '!seen[$0]++' | tail -r >~/.zsh_history.tmp && mv ~/.zsh_history.tmp ~/.zsh_history
  local after=$(wc -l <~/.zsh_history)
  echo "History deduplication: from $before --> $after lines."
}

# Manage docker compose services from ~/docker-services
# Usage: service <name> <docker-compose-args>
# Examples:
#   service redis-admin up -d
function service() {
  local svc=$1
  shift
  docker compose -f ~/docker-services/$svc/docker-compose.yml "$@"
}

# fzf history search - type 'his' instead of Ctrl+R (same as CTRL+R but with edit prompt)
function his() {
  local selected_command
  selected_command=$(fc -ln 1 | fzf --scheme=history --no-sort --height=40% --reverse --query="$*" --tiebreak=index --tac)
  if [[ -n "$selected_command" ]]; then
    local cmd="$selected_command"
    print -z "$cmd"
  fi
}

# set the terminal tab/window title
function set_terminal_title() {
  echo -en "\e]2;$@\a"
}

# sort vscode keybindings.json by key
function sort_vscode_keybindings() {
  local file="$HOME/git/dotfiles/vscode/keybindings.json"
  local tmp=$(mktemp)
  jq 'sort_by(.key)' "$file" > "$tmp" && mv "$tmp" "$file"
}


########################################################################
# HISTORY
HISTSIZE=10000
SAVEHIST=50000
export HISTFILE=~/.zsh_history
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt HIST_REDUCE_BLANKS

########################################################################
# MISE
export MISE_STATE_DIR="$HOME/.mise/state"
eval "$(mise activate zsh)"

########################################################################
# ZOXIDE
eval "$(zoxide init zsh --cmd ji)"

########################################################################
# EDITOR
export EDITOR=hx

########################################################################
# ALIASES
# file explorers/management
alias 'll'='eza -laT --level 1'
alias 'rm'='rm -rf'
alias 'cd..'='cd ..'
alias 'y'='yazy_cd'
# Notes
alias 'notes'='$EDITOR ~/notes'
# make python3 as default
alias 'python'='python3'
alias 'sourcevenv'='source .venv/bin/activate'
# edit .zshrc
alias "editrc"="$EDITOR ~/.zshrc"
alias "sourcerc"="source ~/.zshrc"
alias "catrc"="cat ~/.zshrc"
# docker compose
alias 'dc'='docker compose'
# Vim
alias "vim"="nvim"
# AI
alias "danger"="claude --dangerously-skip-permissions"
alias "plan"="claude --permission-mode plan"
alias "st"="set_terminal_title"

########################################################################
# PRIVATE
[[ -f "$HOME/.zshrc_private" ]] && source "$HOME/.zshrc_private"

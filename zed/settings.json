{
  "document_symbols": "off",
  "text_rendering_mode": "platform_default",
  "ui_font_weight": 400.0,
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "openrouter/auto"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "vim_mode": false,
  "autoscroll_on_clicks": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "scrollbar": {
    "show": "never",
  },
  "minimap": {
    "show": "always",
    "max_width_columns": 60,
  },
  "soft_wrap": "editor_width",
  "gutter": {
    "min_line_number_digits": 3,
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "vertical_scroll_margin": 14.0,
  "tabs": {
    "file_icons": false,
    "show_close_button": "hover",
  },
  "tab_bar": {
    "show": true,
  },
  "terminal": {
    "font_family": "Agave Nerd Font",
    "font_size": 12.0,
    "scrollbar": {
      "show": "always",
    },
    "dock": "right",
  },
  "ui_font_size": 12.0,
  "buffer_font_size": 11.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Soft",
    "dark": "Snazzy Theme"
  },
  "collaboration_panel": {
    "button": false,
  },
}
